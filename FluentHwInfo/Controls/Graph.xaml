<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="FluentHwInfo.Controls.Graph"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Controls"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <Border
        Padding="0,0,0,0"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
        BorderThickness="1"
        CornerRadius="4">

        <Grid CornerRadius="3.3">
            <lvc:CartesianChart
                x:Name="Chart"
                Height="80"
                Margin="-3,0,-3,-2"
                HorizontalAlignment="Stretch"
                AnimationsSpeed="00:00:00"
                Background="Transparent"
                CornerRadius="20"
                DrawMargin="{Binding ChartMargin, ElementName=Root}"
                Sections="{Binding Sections, ElementName=Root}"
                Series="{Binding Series, ElementName=Root}"
                TooltipPosition="Hidden"
                XAxes="{Binding XAxes, ElementName=Root}"
                YAxes="{Binding YAxes, ElementName=Root}" />

            <Canvas
                x:Name="HoverCanvas"
                Height="80"
                Margin="-3,0,-3,-2"
                HorizontalAlignment="Stretch"
                IsHitTestVisible="False">

                <Ellipse
                    x:Name="HoverCircle"
                    Width="8"
                    Height="8"
                    StrokeThickness="1"
                    Visibility="Collapsed" />

                <Border
                    x:Name="CurrentValueLabelBorder"
                    Width="32"
                    Padding="4,2"
                    CornerRadius="3"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="CurrentValueLabelText"
                        HorizontalAlignment="Center"
                        FontSize="10"
                        TextAlignment="Center" />
                </Border>

                <Border
                    x:Name="ThresholdValueLabelBorder"
                    Width="32"
                    Padding="4,2"
                    CornerRadius="3"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="ThresholdValueLabelText"
                        HorizontalAlignment="Center"
                        FontSize="10"
                        TextAlignment="Center" />
                </Border>
            </Canvas>
        </Grid>
    </Border>
</UserControl>
