<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentHwInfo.Views.CPUPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:local1="using:FluentHwInfo.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <!--  List View  -->
            <RowDefinition Height="*" />
            <!--  Action Button  -->
            <RowDefinition Height="90" />

        </Grid.RowDefinitions>

        <!--  List View  -->
        <StackPanel Grid.Row="0">
            <Grid Margin="55,0,26,0" VerticalAlignment="Bottom">
                <Grid.RowDefinitions>
                    <RowDefinition Height="45" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" MinWidth="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Height="25"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Sensor" />
                <TextBlock
                    Grid.Column="1"
                    Height="25"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Current" />
                <TextBlock
                    Grid.Column="2"
                    Height="25"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Min" />
                <TextBlock
                    Grid.Column="3"
                    Height="25"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Max" />
                <TextBlock
                    Grid.Column="4"
                    Height="25"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource Font_TextBlockOutputDisplay}"
                    Text="Avg" />
            </Grid>

            <!--  Divider  -->
            <Border
                Grid.Row="1"
                Height="1"
                Margin="0,0,0,8"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!--  List View  -->
            <ListView
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="6"
                Padding="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                ItemsSource="{x:Bind ViewModel.SensorList, Mode=OneWay}"
                SelectionMode="Multiple">

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local1:SensorRowViewModel">
                        <Grid Padding="0,0,5,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="140" />
                                <ColumnDefinition Width="*" MinWidth="65" />
                                <ColumnDefinition Width="*" MinWidth="65" />
                                <ColumnDefinition Width="*" MinWidth="65" />
                                <ColumnDefinition Width="*" MinWidth="65" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind Name, Mode=OneWay}" />

                            <TextBlock
                                Grid.Column="1"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind CurrentValue, Mode=OneWay}" />

                            <TextBlock
                                Grid.Column="2"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind MinimumValue, Mode=OneWay}" />

                            <TextBlock
                                Grid.Column="3"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind MaximumValue, Mode=OneWay}" />

                            <TextBlock
                                Grid.Column="4"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind AverageValue, Mode=OneWay}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <Button
            Grid.Row="1"
            Margin="14"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="PinToWidget_Click"
            Content="Pin to Widget"
            Style="{StaticResource AccentButtonStyle}">
            <Button.ContentTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="16" Glyph="&#xE93A;" />
                        <TextBlock VerticalAlignment="Center" Text="{Binding}" />
                    </StackPanel>
                </DataTemplate>
            </Button.ContentTemplate>
        </Button>
    </Grid>
</Page>