<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FluentHwInfo.Views.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:FluentHwInfo.ViewModels"
    Title="WidgetWindow"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  custom title bar  -->
        <Grid
            x:Name="CustomTitleBar"
            Grid.Row="0"
            Height="22"
            Background="Transparent">

            <Border
                Width="34"
                Height="4"
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Background="{ThemeResource TextFillColorTertiaryBrush}"
                CornerRadius="2" />
        </Grid>

        <!--  back to app button currently in title bar too  -->
        <Button
            Grid.Row="0"
            Width="32"
            Height="24"
            Margin="4"
            Padding="0"
            HorizontalAlignment="Left"
            Click="BackToDashboard_Click"
            Style="{StaticResource SubtleButtonStyle}"
            ToolTipService.ToolTip="Back to Main Application">
            <FontIcon
                FontSize="13"
                FontWeight="SemiLight"
                Glyph="&#xE944;" />
        </Button>


        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel
                Grid.Row="1"
                Padding="8,0,8,6"
                Spacing="0">

                <ItemsControl ItemsSource="{x:Bind ViewModel.PinnedSensors, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:WidgetSensorViewModel">

                            <StackPanel
                                Height="130"
                                Margin="0,0,0,0"
                                Background="Transparent"
                                Spacing="4">

                                <!--  status header with sensor name and current value  -->
                                <Grid
                                    Height="24"
                                    Padding="0,0,6,0"
                                    HorizontalAlignment="Stretch"
                                    ColumnSpacing="0">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--  toggle panel button  -->
                                    <Button
                                        Grid.Column="0"
                                        Width="32"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Click="{x:Bind ToggleControlPanel}"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Visibility="Visible">

                                        <FontIcon
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Glyph="&#xE90C;" />
                                    </Button>

                                    <!--  current max y-axis value  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        Padding="2,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind ActualYMaxText, Mode=OneWay}" />

                                    <!--  sensor name  -->
                                    <TextBlock
                                        Grid.Column="2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind SensorName, Mode=OneWay}" />

                                    <!--  current value  -->
                                    <TextBlock
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind CurrentValueText, Mode=OneWay}" />
                                </Grid>

                                <!--  left: control buttons, right: LiveChart graph  -->
                                <Grid ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!--  control buttons  -->
                                    <Grid
                                        Grid.Column="0"
                                        Width="36"
                                        Padding="0,0,4,0"
                                        RowSpacing="4"
                                        Visibility="{x:Bind ControlPanelVisibility, Mode=OneWay}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Button
                                            Grid.Row="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Click="{x:Bind IncreaseYMax}"
                                            ToolTipService.ToolTip="Y-Achse vergrößern">
                                            <FontIcon FontSize="12" Glyph="&#xE70E;" />
                                        </Button>

                                        <Button
                                            Grid.Row="1"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Click="{x:Bind DecreaseYMax}"
                                            ToolTipService.ToolTip="Y-Achse verkleinern">
                                            <FontIcon FontSize="12" Glyph="&#xE70D;" />
                                        </Button>

                                        <ToggleButton
                                            Grid.Row="2"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Content="A"
                                            FontSize="12"
                                            FontWeight="Normal"
                                            IsChecked="{x:Bind IsAutoScaled, Mode=TwoWay}"
                                            ToolTipService.ToolTip="Auto-Skalierung" />

                                    </Grid>

                                    <!--  the actual LiveChart graph  -->
                                    <Border
                                        Grid.Column="1"
                                        Padding="0,0,0,0"
                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                                        BorderThickness="0"
                                        CornerRadius="4">

                                        <lvc:CartesianChart
                                            Height="100"
                                            Margin="-6,0,-6,0"
                                            HorizontalAlignment="Stretch"
                                            AnimationsSpeed="00:00:00"
                                            Background="Transparent"
                                            DrawMargin="{x:Bind ChartMargin, Mode=OneWay}"
                                            Series="{x:Bind Series, Mode=OneWay}"
                                            TooltipPosition="Auto"
                                            XAxes="{x:Bind XAxes, Mode=OneWay}"
                                            YAxes="{x:Bind YAxes, Mode=OneWay}" />
                                    </Border>
                                </Grid>

                                <!--  control buttons on position 2  -->
                                <Grid
                                    Height="28"
                                    ColumnSpacing="4"
                                    Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        Grid.Column="1"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Click="{x:Bind IncreaseYMax}"
                                        ToolTipService.ToolTip="Y-Achse vergrößern">
                                        <FontIcon FontSize="12" Glyph="&#xE70E;" />
                                    </Button>

                                    <Button
                                        Grid.Column="2"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Click="{x:Bind DecreaseYMax}"
                                        ToolTipService.ToolTip="Y-Achse verkleinern">
                                        <FontIcon FontSize="12" Glyph="&#xE70D;" />
                                    </Button>

                                    <ToggleButton
                                        Grid.Column="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Content="A"
                                        FontSize="12"
                                        FontWeight="Normal"
                                        IsChecked="{x:Bind IsAutoScaled, Mode=TwoWay}"
                                        ToolTipService.ToolTip="Auto-Skalierung" />
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>