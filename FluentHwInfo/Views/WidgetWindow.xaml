<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FluentHwInfo.Views.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:FluentHwInfo.ViewModels"
    Title="WidgetWindow"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Live Monitor"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE950;" />
            </TitleBar.IconSource>
        </TitleBar>

        <StackPanel
            Grid.Row="1"
            Padding="16"
            Spacing="12">

            <ItemsControl ItemsSource="{x:Bind ViewModel.PinnedSensors, Mode=OneWay}">

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:WidgetSensorViewModel">

                        <StackPanel Margin="0,0,0,24" Spacing="12">

                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind SensorName, Mode=OneWay}" />

                            <TextBlock
                                FontSize="28"
                                FontWeight="SemiBold"
                                Text="{x:Bind CurrentValueText, Mode=OneWay}" />

                            <Border
                                Padding="0,0,0,0"
                                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                                BorderThickness="0"
                                CornerRadius="4">

                                <lvc:CartesianChart
                                    Height="80"
                                    Margin="-6,0,-6,0"
                                    HorizontalAlignment="Stretch"
                                    AnimationsSpeed="00:00:00"
                                    Background="Transparent"
                                    DrawMargin="{x:Bind ChartMargin, Mode=OneWay}"
                                    Series="{x:Bind Series, Mode=OneWay}"
                                    TooltipPosition="Auto"
                                    XAxes="{x:Bind XAxes, Mode=OneWay}"
                                    YAxes="{x:Bind YAxes, Mode=OneWay}" />
                            </Border>

                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button
                HorizontalAlignment="Right"
                Click="BackToDashboard_Click"
                Style="{StaticResource SubtleButtonStyle}">
                <FontIcon Glyph="&#xE737;" />
            </Button>
        </StackPanel>
    </Grid>
</Window>