<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FluentHwInfo.Views.WidgetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WidgetWindow"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            Title="Live Monitor"
            Grid.Row="0"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE950;" />
            </TitleBar.IconSource>
        </TitleBar>

        <StackPanel
            Grid.Row="1"
            Padding="16"
            Spacing="12">
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="CPU PACKAGE" />
            <TextBlock
                x:Name="CpuPowerValue"
                FontSize="28"
                FontWeight="SemiBold"
                Text="45.2 W" />

            <Button
                HorizontalAlignment="Right"
                Click="BackToDashboard_Click"
                Style="{StaticResource SubtleButtonStyle}">
                <FontIcon Glyph="&#xE737;" />
            </Button>
        </StackPanel>
    </Grid>
</Window>
