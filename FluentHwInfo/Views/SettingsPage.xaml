<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentHwInfo.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel
            Margin="24"
            HorizontalAlignment="Stretch"
            Spacing="4">

            <TextBlock
                Margin="0,0,0,12"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Settings" />


            <!--  general settings  -->
            <TextBlock
                Margin="1,8,0,6"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="General Settings" />

            <controls:SettingsCard
                Description="Select your preferred color mode for the application"
                Header="App Theme"
                HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                <ComboBox
                    x:Name="ThemeComboBox"
                    Width="150"
                    SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="System Default" Tag="Default" />
                    <ComboBoxItem Content="Light" Tag="Light" />
                    <ComboBoxItem Content="Dark" Tag="Dark" />
                </ComboBox>
            </controls:SettingsCard>

            <!--  engine settings  -->
            <controls:SettingsCard
                Description="How fast the hardware sensors should be polled"
                Header="Update Interval"
                HeaderIcon="{ui:FontIcon Glyph=&#xE916;}">
                <ComboBox
                    x:Name="IntervalComboBox"
                    Width="150"
                    SelectionChanged="IntervalComboBox_SelectionChanged">
                    <ComboBoxItem Content="100ms" Tag="100" />
                    <ComboBoxItem Content="250ms" Tag="250" />
                    <ComboBoxItem Content="500ms" Tag="500" />
                    <ComboBoxItem Content="1000ms" Tag="1000" />
                    <ComboBoxItem Content="2000ms" Tag="2000" />
                </ComboBox>
            </controls:SettingsCard>

            <!--  behavior settings  -->
            <controls:SettingsCard
                Description="Hide the app to the system tray when all windows are minimized"
                Header="Minimize to System Tray"
                HeaderIcon="{ui:FontIcon Glyph=&#xE744;}">
                <ToggleSwitch
                    x:Name="MinimizeToTrayToggle"
                    OffContent="Off"
                    OnContent="On"
                    Toggled="MinimizeToTrayToggle_Toggled" />
            </controls:SettingsCard>


            <!--  widget settings  -->
            <TextBlock
                Margin="1,20,0,6"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Widget Appearance" />

            <!--  background material  -->
            <controls:SettingsExpander
                Description="Choose the transparency effect and color for the widget window."
                Header="Background Material"
                HeaderIcon="{ui:FontIcon Glyph=&#xEF1F;}"
                IsExpanded="False">

                <ComboBox
                    x:Name="BackdropComboBox"
                    Width="160"
                    SelectionChanged="BackdropComboBox_SelectionChanged">
                    <ComboBoxItem Content="Desktop Acrylic" Tag="Acrylic" />
                    <ComboBoxItem Content="System Mica" Tag="Mica" />
                    <ComboBoxItem Content="Solid (No Blur)" Tag="None" />
                </ComboBox>

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Description="Adjust the color transparency (Acrylic only)." Header="Tint Opacity">
                        <Slider
                            x:Name="TintSlider"
                            Width="200"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.05"
                            TickFrequency="0.1"
                            ValueChanged="TintSlider_ValueChanged" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Adjust the brightness transparency (Acrylic only)." Header="Luminosity Opacity">
                        <Slider
                            x:Name="LuminositySlider"
                            Width="200"
                            Maximum="1"
                            Minimum="0"
                            StepFrequency="0.05"
                            TickFrequency="0.1"
                            ValueChanged="LuminositySlider_ValueChanged" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Choose between the Windows accent color or a custom color." Header="Background Color Source">
                        <ComboBox
                            x:Name="ColorSourceComboBox"
                            Width="160"
                            SelectionChanged="ColorSourceComboBox_SelectionChanged">
                            <ComboBoxItem Content="Windows Accent" Tag="Accent" />
                            <ComboBoxItem Content="Custom Color" Tag="Custom" />
                        </ComboBox>
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Select the custom color for the background." Header="Custom Background Color">
                        <controls:ColorPickerButton x:Name="WidgetBackgroundColorPicker" />
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <!--  graph fill color setting  -->
            <controls:SettingsExpander
                Description="Choose the color source for the LiveChart graph."
                Header="Graph Fill Color"
                HeaderIcon="{ui:FontIcon Glyph=&#xE790;}"
                IsExpanded="False">

                <ComboBox
                    x:Name="GraphColorSourceComboBox"
                    Width="160"
                    SelectionChanged="GraphColorSourceComboBox_SelectionChanged">
                    <ComboBoxItem Content="Windows Accent" Tag="Accent" />
                    <ComboBoxItem Content="Custom Color" Tag="Custom" />
                </ComboBox>

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Description="Select the custom fill color for the graph." Header="Custom Graph Color">
                        <controls:ColorPickerButton x:Name="GraphColorPicker" />
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <!--  number of graph points  -->
            <controls:SettingsCard
                Description="How many data points should be displayed in the widget graph"
                Header="Number of Graph Data Points"
                HeaderIcon="{ui:FontIcon Glyph=&#xE9D2;}">
                <ComboBox
                    x:Name="GraphDataPointsComboBox"
                    Width="150"
                    SelectionChanged="GraphDataPointsComboBox_SelectionChanged">
                    <ComboBoxItem Content="80 Points" Tag="80" />
                    <ComboBoxItem Content="90 Points" Tag="90" />
                    <ComboBoxItem Content="100 Points" Tag="100" />
                    <ComboBoxItem Content="110 Points" Tag="110" />
                    <ComboBoxItem Content="120 Points" Tag="120" />
                    <ComboBoxItem Content="130 Points" Tag="130" />
                    <ComboBoxItem Content="140 Points" Tag="140" />
                    <ComboBoxItem Content="150 Points" Tag="150" />
                    <ComboBoxItem Content="160 Points" Tag="160" />
                </ComboBox>
            </controls:SettingsCard>


            <!--  reset settings  -->
            <TextBlock
                Margin="1,20,0,6"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="Reset" />

            <controls:SettingsExpander
                Description="Restore individual persisted state files to their defaults. The app will restart after confirmation."
                Header="Reset to Defaults"
                HeaderIcon="{ui:FontIcon Glyph=&#xE777;}"
                IsExpanded="False">

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Description="Theme, backdrop, update interval, graph appearance, tray behavior." Header="General Settings">
                        <Button Click="ResetGeneralSettings_Click" Content="Reset" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Saved position and size of the dashboard and widget windows." Header="Window Positions">
                        <Button Click="ResetWindowStates_Click" Content="Reset" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Per-sensor visibility, thresholds, graph scaling, and pinned selection." Header="Sensor States">
                        <Button Click="ResetSensorStates_Click" Content="Reset" />
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>


            <!--  about section  -->
            <TextBlock
                Margin="1,20,0,6"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="About &amp; Open Source" />

            <controls:SettingsExpander
                Description="© 2026 Daniel Čech. All rights reserved."
                Header="Fluent HwInfo"
                HeaderIcon="{ui:FontIcon Glyph=&#xE946;}">

                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    IsTextSelectionEnabled="True"
                    Text="Version 0.2.1" />

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Header="Developer Profile">
                        <HyperlinkButton Content="Github" NavigateUri="https://github.com/cechout" />
                    </controls:SettingsCard>
                    <controls:SettingsCard Header="Project Repository">
                        <HyperlinkButton Content="Github" NavigateUri="https://github.com/cechout/fluent-hwinfo" />
                    </controls:SettingsCard>
                </controls:SettingsExpander.Items>
            </controls:SettingsExpander>

            <controls:SettingsExpander
                Description="This application is built using the following open source projects."
                Header="Third-Party Libraries"
                HeaderIcon="{ui:FontIcon Glyph=&#xE8F1;}">

                <controls:SettingsExpander.Items>
                    <controls:SettingsCard Header="Windows App SDK">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/microsoft/WindowsAppSDK" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="Windows Community Toolkit">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/CommunityToolkit/WindowsCommunityToolkit" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="WinUIEx">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/dotMorten/WinUIEx" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="LiveCharts2">
                        <HyperlinkButton Content="Website" NavigateUri="https://livecharts.dev/" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="LibreHardwareMonitor">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/LibreHardwareMonitor/LibreHardwareMonitor" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="H.NotifyIcon">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/HavenDV/H.NotifyIcon" />
                    </controls:SettingsCard>

                </controls:SettingsExpander.Items>

                <!--<controls:SettingsExpander.Items>
                    <controls:SettingsCard Description="Microsoft UI framework and tools" Header="Windows App SDK">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/microsoft/WindowsAppSDK" />
