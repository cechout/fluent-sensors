                    <controls:SettingsCard Description="Interactive charts and data visualization" Header="LiveCharts2">
                        <HyperlinkButton Content="Website" NavigateUri="https://livecharts.dev/" />
                    </controls:SettingsCard>

                    <controls:SettingsCard Description="Open source hardware monitoring API" Header="LibreHardwareMonitor">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/LibreHardwareMonitor/LibreHardwareMonitor" />
