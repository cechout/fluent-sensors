                    <controls:SettingsCard Description="System Tray integration for WinUI" Header="H.NotifyIcon">
                        <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/HavenDV/H.NotifyIcon" />
                    </controls:SettingsCard>

                </controls:SettingsExpander.Items>-->
            </controls:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</Page>