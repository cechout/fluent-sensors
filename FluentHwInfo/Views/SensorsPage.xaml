<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentHwInfo.Views.SensorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:local1="using:FluentHwInfo.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="16,0,16,0">

            <ItemsControl ItemsSource="{x:Bind ViewModel.HardwareGroups, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local1:HardwareGroupViewModel">

                        <!--  here is the overall padding for the whole expander content  -->
                        <Expander
                            Margin="0,16,0,0"
                            Padding="0,0,0,0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            ExpandDirection="Down"
                            IsExpanded="False">

                            <Expander.Header>
                                <TextBlock
                                    FontSize="15"
                                    Style="{ThemeResource SubtitleTextBlockStyle}"
                                    Text="{x:Bind HardwareName, Mode=OneWay}" />
                            </Expander.Header>

                            <Expander.Content>
                                <StackPanel>

                                    <!--  ListView Header  -->
                                    <!--  here the manual pixel padding for the custom ListView header can be set  -->
                                    <Grid Margin="52,12,22,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" MinWidth="140" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="Sensor" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="Current" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="Min" />
                                        <TextBlock
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="Max" />
                                        <TextBlock
                                            Grid.Column="4"
                                            HorizontalAlignment="Right"
                                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                                            Text="Avg" />
                                    </Grid>

                                    <!--  Dividing Border  -->
                                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                                    <!--  The actual ListView with all the Sensors  -->
                                    <ListView
                                        Padding="2,2,2,4"
                                        HorizontalContentAlignment="Stretch"
                                        ItemsSource="{x:Bind Sensors, Mode=OneWay}"
                                        Loaded="SensorsListView_Loaded"
                                        SelectionChanged="SensorsListView_SelectionChanged"
                                        SelectionMode="Multiple">

                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="local1:SensorRowViewModel">

                                                <!--  here the padding inside a single sensor row can be set  -->
                                                <Grid Padding="0,0,4,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*" MinWidth="140" />
                                                        <ColumnDefinition Width="*" MinWidth="65" />
                                                        <ColumnDefinition Width="*" MinWidth="65" />
                                                        <ColumnDefinition Width="*" MinWidth="65" />
                                                        <ColumnDefinition Width="*" MinWidth="65" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock
                                                        Grid.Column="0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                        Text="{x:Bind Name, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                        Text="{x:Bind CurrentValue, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="2"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                        Text="{x:Bind MinimumValue, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="3"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                        Text="{x:Bind MaximumValue, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="4"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                        Text="{x:Bind AverageValue, Mode=OneWay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                </StackPanel>
                            </Expander.Content>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border
            Grid.Row="1"
            Padding="12,12,16,12"
            Background="{ThemeResource ControlFillColorTertiaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">

            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">

                <!--  Reset Min/Max Button  -->
                <Button
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Content="Reset Min/Max" />

                <!--  Pin to Widget Button  -->
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="PinToWidget_Click"
                    Content="Pin to Widget"
                    Style="{ThemeResource AccentButtonStyle}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE93A;" />
                                <TextBlock VerticalAlignment="Center" Text="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>