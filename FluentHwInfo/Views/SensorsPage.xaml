<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentHwInfo.Views.SensorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:local1="using:FluentHwInfo.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <!--  header: control buttons  -->
        <!--  (border has background: {ThemeResource SolidBackgroundFillColorTertiaryBrush})  -->
        <Border
            Grid.Row="0"
            Padding="12,8,16,8"
            Background="Transparent"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="Sensor List" />

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="0">

                    <!--  reset min max button  -->
                    <Button
                        Height="36"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Click="ResetMinMax_Click"
                        Content="Reset Values"
                        Style="{ThemeResource SubtleButtonStyle}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="15" Glyph="&#xE72C;" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <!--  pin to widget button  -->
                    <Button
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Click="PinToWidget_Click"
                        Content="Pin to Widget"
                        Style="{ThemeResource SubtleButtonStyle}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="16" Glyph="&#xE93A;" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <!--  hide sensors button  -->
                    <Button
                        Height="36"
                        VerticalAlignment="Bottom"
                        Click="HideSensors_Click"
                        Content="Hide Sensor(s)"
                        Style="{ThemeResource SubtleButtonStyle}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="15" Glyph="&#xED1A;" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <!--  show hidden sensors button  -->
                    <Button
                        Height="36"
                        VerticalAlignment="Bottom"
                        Click="ShowHiddenSensors_Click"
                        Content="Show Hidden Sensors"
                        IsEnabled="{x:Bind ViewModel.HasHiddenSensors, Mode=OneWay}"
                        Style="{ThemeResource SubtleButtonStyle}">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="15" Glyph="&#xE890;" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!--  header: items header labels  -->
        <!--  (border has background: {ThemeResource SolidBackgroundFillColorTertiaryBrush})  -->
        <Border Grid.Row="1" Background="Transparent">
            <Grid HorizontalAlignment="Stretch">

                <Grid Margin="32,12,32,12" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="140" />
                        <ColumnDefinition Width="*" MinWidth="65" />
                        <ColumnDefinition Width="*" MinWidth="65" />
                        <ColumnDefinition Width="*" MinWidth="65" />
                        <ColumnDefinition Width="*" MinWidth="65" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Margin="36,0,0,0"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Sensor" />
                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Current" />
                    <TextBlock
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Min" />
                    <TextBlock
                        Grid.Column="3"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Max" />
                    <TextBlock
                        Grid.Column="4"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="Avg" />
                </Grid>

                <Border
                    Height="1"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            </Grid>
        </Border>


        <!--  content: scrollviewer with all the cards of different hardware groups  -->
        <ScrollViewer
            x:Name="MainScrollViewer"
            Grid.Row="2"
            Padding="16,0,16,0">

            <ItemsControl
                x:Name="HardwareItemsControl"
                Margin="0,0,0,16"
                ItemsSource="{x:Bind ViewModel.HardwareGroups, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local1:HardwareGroupViewModel">

                        <!--  settings expander (containing all the sensors for one hardware group)  -->
                        <controls:SettingsExpander
                            Margin="0,16,0,0"
                            Header="{x:Bind HardwareName, Mode=OneWay}"
                            IsExpanded="False"
                            ItemsSource="{x:Bind Sensors, Mode=OneWay}"
                            Loaded="SettingsExpander_Loaded">

                            <!--<ComboBox MinWidth="150" SelectedIndex="0">
                            <ComboBoxItem>All Sensors</ComboBoxItem>
                            <ComboBoxItem>Custom Selection</ComboBoxItem>
                            </ComboBox>-->

                            <!--  column labels  -->
                            <controls:SettingsExpander.ItemsHeader>
                                <controls:SettingsCard
                                    MinHeight="0"
                                    Padding="16,12,16,8"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="0"
                                    ContentAlignment="Vertical"
                                    CornerRadius="0">

                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" MinWidth="140" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="36,0,0,0"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Sensor" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Current" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Min" />
                                        <TextBlock
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Max" />
                                        <TextBlock
                                            Grid.Column="4"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Avg" />
                                    </Grid>

                                </controls:SettingsCard>
                            </controls:SettingsExpander.ItemsHeader>

                            <!--  items  -->
                            <controls:SettingsExpander.ItemTemplate>
                                <DataTemplate x:DataType="local1:SensorRowViewModel">

                                    <controls:SettingsCard
                                        MinHeight="0"
                                        Margin="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ContentAlignment="Vertical"
                                        CornerRadius="0">

                                        <local:SensorCardControl HorizontalAlignment="Stretch" ViewModel="{x:Bind}" />

                                    </controls:SettingsCard>

                                </DataTemplate>
                            </controls:SettingsExpander.ItemTemplate>
                        </controls:SettingsExpander>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>


        <InfoBar
            x:Name="NoSensorsInfoBar"
            Title="No sensors selected"
            Grid.Row="2"
            Margin="24"
            VerticalAlignment="Bottom"
            IsClosable="False"
            IsHitTestVisible="False"
            IsOpen="True"
            Message="Please select at least one sensor to pin to the widget."
            Severity="Warning">

            <InfoBar.RenderTransform>
                <TranslateTransform x:Name="InfoBarTransform" Y="100" />
            </InfoBar.RenderTransform>
        </InfoBar>


        <!--  bottom page border with control buttons  -->
        <!--  ControlFillColorTertiaryBrush  -->
        <!--  SolidBackgroundFillColorTertiaryBrush  -->
        <!--  SolidBackgroundFillColorQuarternaryBrush  -->
        <!--<Border
            Grid.Row="3"
            Padding="12,12,16,12"
            Background="{ThemeResource SolidBackgroundFillColorQuarternaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">

            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">

        -->
        <!--  reset min/max button  -->
        <!--
                <Button
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Content="Reset Min/Max" />

        -->
        <!--  pin to widget button  -->
        <!--
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="PinToWidget_Click"
                    Content="Pin to Widget"
                    Style="{ThemeResource AccentButtonStyle}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE93A;" />
                                <TextBlock VerticalAlignment="Center" Text="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </Border>-->
    </Grid>
</Page>