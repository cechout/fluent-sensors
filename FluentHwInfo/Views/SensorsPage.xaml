<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentHwInfo.Views.SensorsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:local1="using:FluentHwInfo.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Padding="16,0,16,0">

            <ItemsControl Margin="0,0,0,16" ItemsSource="{x:Bind ViewModel.HardwareGroups, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local1:HardwareGroupViewModel">

                        <controls:SettingsExpander
                            Margin="0,16,0,0"
                            Header="{x:Bind HardwareName, Mode=OneWay}"
                            IsExpanded="False"
                            ItemsSource="{x:Bind Sensors, Mode=OneWay}">

                            <!--<ComboBox MinWidth="150" SelectedIndex="0">
                                <ComboBoxItem>All Sensors</ComboBoxItem>
                                <ComboBoxItem>Custom Selection</ComboBoxItem>
                            </ComboBox>-->

                            <!--  items header  -->
                            <controls:SettingsExpander.ItemsHeader>
                                <controls:SettingsCard
                                    MinHeight="0"
                                    Padding="16,12,16,8"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="0"
                                    ContentAlignment="Vertical"
                                    CornerRadius="0">

                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" MinWidth="140" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="36,0,0,0"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Sensor" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Current" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Min" />
                                        <TextBlock
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Max" />
                                        <TextBlock
                                            Grid.Column="4"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Avg" />
                                    </Grid>

                                </controls:SettingsCard>
                            </controls:SettingsExpander.ItemsHeader>

                            <!--  items  -->
                            <controls:SettingsExpander.ItemTemplate>
                                <DataTemplate x:DataType="local1:SensorRowViewModel">

                                    <!--  we do not set the margin here, because the SensorCardControl does it itself  -->
                                    <local:SensorCardControl Margin="0,0,0,0" ViewModel="{x:Bind}" />

                                </DataTemplate>
                            </controls:SettingsExpander.ItemTemplate>
                        </controls:SettingsExpander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>


        </ScrollViewer>

        <Border
            Grid.Row="1"
            Padding="12,12,16,12"
            Background="{ThemeResource ControlFillColorTertiaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">

            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">

                <!--  reset min/max button  -->
                <Button
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Content="Reset Min/Max" />

                <!--  pin to widget button  -->
                <Button
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Click="PinToWidget_Click"
                    Content="Pin to Widget"
                    Style="{ThemeResource AccentButtonStyle}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="16" Glyph="&#xE93A;" />
                                <TextBlock VerticalAlignment="Center" Text="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>