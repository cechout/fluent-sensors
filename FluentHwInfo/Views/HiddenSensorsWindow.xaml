<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="FluentHwInfo.Views.HiddenSensorsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FluentHwInfo.Views"
    xmlns:local1="using:FluentHwInfo.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  custom title bar  -->
        <Grid
            x:Name="CustomTitleBar"
            Grid.Row="0"
            Height="28"
            Background="Transparent">

            <TextBlock
                Margin="16,0,0,0"
                VerticalAlignment="Center"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="Hidden Sensors" />
        </Grid>

        <!--  hidden sensors, grouped by hardware, same layout as the main sensor list on SensorsPage  -->
        <ScrollViewer
            Grid.Row="1"
            Padding="16,0,16,0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

            <ItemsControl Margin="0,0,0,16" ItemsSource="{x:Bind ViewModel.HardwareGroups, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="local1:HardwareGroupViewModel">

                        <controls:SettingsExpander
                            Margin="0,16,0,0"
                            Header="{x:Bind HardwareName, Mode=OneWay}"
                            IsExpanded="True"
                            ItemsSource="{x:Bind HiddenSensors, Mode=OneWay}"
                            Loaded="SettingsExpander_Loaded"
                            Visibility="{x:Bind HiddenPanelVisibility, Mode=OneWay}">

                            <!--  items header  -->
                            <!--<controls:SettingsExpander.ItemsHeader>
                                <controls:SettingsCard
                                    MinHeight="0"
                                    Padding="16,12,16,8"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="0"
                                    ContentAlignment="Vertical"
                                    CornerRadius="0">

                                    <Grid HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" MinWidth="140" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                            <ColumnDefinition Width="*" MinWidth="65" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="36,0,0,0"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Sensor" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Current" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Min" />
                                        <TextBlock
                                            Grid.Column="3"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Max" />
                                        <TextBlock
                                            Grid.Column="4"
                                            HorizontalAlignment="Right"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            Text="Avg" />
                                    </Grid>

                                </controls:SettingsCard>
                            </controls:SettingsExpander.ItemsHeader>-->

                            <!--  items  -->
                            <!--<controls:SettingsExpander.ItemTemplate>
                                <DataTemplate x:DataType="local1:SensorRowViewModel">
                                    <controls:SettingsCard
                                        MinHeight="0"
                                        Margin="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ContentAlignment="Vertical"
                                        CornerRadius="0">

                                        <local:SensorCardControl
                                            HorizontalAlignment="Stretch"
                                            IsCompact="True"
                                            ViewModel="{x:Bind}" />
                                    </controls:SettingsCard>
                                </DataTemplate>
                            </controls:SettingsExpander.ItemTemplate>-->

                            <!--  items  -->
                            <controls:SettingsExpander.ItemTemplate>
                                <DataTemplate x:DataType="local1:SensorRowViewModel">
                                    <local:SensorCardControl
                                        HorizontalAlignment="Stretch"
                                        IsCompact="True"
                                        ViewModel="{x:Bind}" />
                                </DataTemplate>
                            </controls:SettingsExpander.ItemTemplate>

                        </controls:SettingsExpander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  bottom bar with the restore action  -->
        <Border
            Grid.Row="2"
            Padding="16,12,16,12"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">

            <Button
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Click="RestoreSelected_Click"
                Content="Restore Selected" />
        </Border>
    </Grid>
</Window>