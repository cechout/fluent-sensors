<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="FluentSensors.Controls.SensorRow.SensorRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fhCommon="using:FluentSensors.Common"
    xmlns:fhSensors="using:FluentSensors.Features.Sensors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <ResourceDictionary x:Key="Default">

                    <!--  whole row  -->
                    <SolidColorBrush x:Key="CustomCheckedBackgroundBrush" Color="#19FFFFFF" />
                    <SolidColorBrush x:Key="CustomCheckedHoverBrush" Color="#14FFFFFF" />

                    <!--  threshold  -->
                    <SolidColorBrush x:Key="ThresholdIndicatorHoverBrush" Color="#13FFFFFF" />
                    <SolidColorBrush x:Key="ThresholdIndicatorPressedBrush" Color="#0CFFFFFF" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">

                    <!--  whole row  -->
                    <SolidColorBrush x:Key="CustomCheckedBackgroundBrush" Color="#FFF8F8F8" />
                    <SolidColorBrush x:Key="CustomCheckedHoverBrush" Color="#FFFAFAFA" />

                    <!--  threshold  -->
                    <SolidColorBrush x:Key="ThresholdIndicatorHoverBrush" Color="#FFEFEFEF" />
                    <SolidColorBrush x:Key="ThresholdIndicatorPressedBrush" Color="#FFF3F3F3" />
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid
        x:Name="RootGrid"
        HorizontalAlignment="Stretch"
        Background="Transparent"
        PointerEntered="RootGrid_PointerEntered"
        PointerExited="RootGrid_PointerExited"
        PointerPressed="RootGrid_PointerPressed"
        PointerReleased="RootGrid_PointerReleased"
        Tapped="RootGrid_Tapped">
        <!--  border to control color and height of spacing between each item  -->
        <Border
            x:Name="CardBackground"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            CornerRadius="0" />

        <Grid
            x:Name="CardContent"
            Padding="16,2,16,2"
            HorizontalAlignment="Stretch"
            DataContext="{x:Bind ViewModel, Mode=OneWay}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    x:Name="NameColumn"
                    Width="5*"
                    MinWidth="140" />
                <ColumnDefinition
                    x:Name="ThresholdColumn"
                    Width="36"
                    MinWidth="36" />
                <ColumnDefinition
                    x:Name="CurrentColumn"
                    Width="2*"
                    MinWidth="65" />
                <ColumnDefinition
                    x:Name="MinimumColumn"
                    Width="2*"
                    MinWidth="65" />
                <ColumnDefinition
                    x:Name="MaximumColumn"
                    Width="2*"
                    MinWidth="65" />
                <ColumnDefinition
                    x:Name="AverageColumn"
                    Width="2*"
                    MinWidth="65" />
                <ColumnDefinition
                    x:Name="UnitColumn"
                    Width="0"
                    MinWidth="0" />
            </Grid.ColumnDefinitions>

            <!--  checkbox with sensor name  -->
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8">

                <CheckBox
                    MinWidth="0"
                    IsChecked="{x:Bind ViewModel.IsSelected, Mode=OneWay}"
                    IsHitTestVisible="False" />

                <TextBlock
                    VerticalAlignment="Center"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.Name, Mode=OneWay}" />
            </StackPanel>

            <!--  threshold indicator/button  -->
            <!--  opens the threshold config flyout on click  -->
            <Border
                x:Name="ThresholdIndicatorBorder"
                Grid.Column="1"
                Width="34"
                Padding="5,2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{x:Bind ViewModel.ThresholdIndicatorBrush, Mode=OneWay}"
                CornerRadius="3"
                Opacity="0.95"
                PointerEntered="ThresholdIndicatorBorder_PointerEntered"
                PointerExited="ThresholdIndicatorBorder_PointerExited"
                PointerPressed="ThresholdIndicatorBorder_PointerPressed"
                PointerReleased="ThresholdIndicatorBorder_PointerReleased"
                Tapped="ThresholdIndicatorBorder_Tapped">

                <FlyoutBase.AttachedFlyout>
                    <Flyout
                        x:Name="ThresholdFlyout"
                        Placement="Bottom"
                        ShouldConstrainToRootBounds="False">

                        <Flyout.FlyoutPresenterStyle>
                            <Style TargetType="FlyoutPresenter">
                                <Setter Property="Padding" Value="0,0,0,0" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </Flyout.FlyoutPresenterStyle>

                        <StackPanel
                            Width="105"
                            Padding="4"
                            Spacing="8">

                            <!--  title row with close button  -->
                            <Grid ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />

                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    Margin="4,3,10,0"
                                    VerticalAlignment="Center"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Text="Threshold Config" />

                                <Button
                                    x:Name="ThresholdCloseButton"
                                    Grid.Column="0"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Click="ThresholdCloseButton_Click"
                                    Style="{StaticResource SubtleButtonStyle}">
                                    <FontIcon FontSize="12" Glyph="&#xE711;" />
                                </Button>
                            </Grid>

                            <Grid Height="90" ColumnSpacing="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  increase / decrease / toggle  -->
                                <Grid Grid.Column="0" RowSpacing="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <RepeatButton
                                        Grid.Row="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Click="{x:Bind ViewModel.Threshold.Increase}"
                                        ToolTipService.ToolTip="Increase Threshold">
                                        <FontIcon FontSize="12" Glyph="&#xE70E;" />
                                    </RepeatButton>

                                    <RepeatButton
                                        Grid.Row="1"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Click="{x:Bind ViewModel.Threshold.Decrease}"
                                        ToolTipService.ToolTip="Decrease Threshold">
                                        <FontIcon FontSize="12" Glyph="&#xE70D;" />
                                    </RepeatButton>

                                    <ToggleButton
                                        Grid.Row="2"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Content="T"
                                        FontSize="12"
                                        FontWeight="Normal"
                                        IsChecked="{x:Bind ViewModel.Threshold.IsEnabled, Mode=TwoWay}"
                                        ToolTipService.ToolTip="Toggle Threshold-Line" />
                                </Grid>

                                <!--  direction + color  -->
                                <Grid Grid.Column="1" RowSpacing="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <ToggleButton
                                        Grid.Row="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        IsChecked="{x:Bind ViewModel.Threshold.IsAboveDirection, Mode=TwoWay}"
                                        ToolTipService.ToolTip="Mark Above Threshold">
                                        <FontIcon
                                            FontSize="12"
                                            Glyph="&#xEDE1;"
                                            RenderTransformOrigin="0.5,0.5">
                                            <FontIcon.RenderTransform>
                                                <RotateTransform Angle="-90" />
                                            </FontIcon.RenderTransform>
                                        </FontIcon>
                                    </ToggleButton>

                                    <Button
                                        Grid.Row="1"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch">
                                        <Border
                                            Background="{x:Bind ViewModel.Threshold.ColorBrush, Mode=OneWay}"
                                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3" />

                                        <Button.Flyout>
                                            <Flyout Placement="Bottom" ShouldConstrainToRootBounds="False">
                                                <controls:ColorPicker
                                                    ColorSpectrumShape="Box"
                                                    IsAlphaEnabled="False"
                                                    IsAlphaSliderVisible="False"
                                                    IsAlphaTextInputVisible="False"
                                                    IsColorChannelTextInputVisible="True"
                                                    IsColorPaletteVisible="True"
                                                    IsColorSliderVisible="True"
                                                    IsColorSpectrumVisible="True"
                                                    Color="{x:Bind ViewModel.Threshold.Color, Mode=TwoWay}" />
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>

                                    <ToggleButton
                                        Grid.Row="2"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        IsChecked="{x:Bind ViewModel.Threshold.IsBelowDirection, Mode=TwoWay}"
                                        ToolTipService.ToolTip="Mark Under Threshold">
                                        <FontIcon
                                            FontSize="12"
                                            Glyph="&#xEDE1;"
                                            RenderTransformOrigin="0.5,0.5">
                                            <FontIcon.RenderTransform>
                                                <RotateTransform Angle="90" />
                                            </FontIcon.RenderTransform>
                                        </FontIcon>
                                    </ToggleButton>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Flyout>
                </FlyoutBase.AttachedFlyout>

                <TextBlock
                    Margin="0,0,0,1"
                    HorizontalAlignment="Center"
                    FontSize="10"
                    Text="{x:Bind ViewModel.ThresholdIndicatorText, Mode=OneWay}"
                    TextAlignment="Center" />
            </Border>

            <!--  current value  -->
            <TextBlock
                x:Name="CurrentValueText"
                Grid.Column="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontWeight="Normal"
                Foreground="{x:Bind ViewModel.CurrentValueColor, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.CurrentValue, Mode=OneWay}" />

            <!--  minimum value  -->
            <TextBlock
                x:Name="MinimumValueText"
                Grid.Column="3"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontWeight="Normal"
                Foreground="{x:Bind ViewModel.MinimumValueColor, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.MinimumValue, Mode=OneWay}" />

            <!--  maximum value  -->
            <TextBlock
                x:Name="MaximumValueText"
                Grid.Column="4"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontWeight="Normal"
                Foreground="{x:Bind ViewModel.MaximumValueColor, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.MaximumValue, Mode=OneWay}" />

            <!--  average value  -->
            <TextBlock
                x:Name="AverageValueText"
                Grid.Column="5"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                FontWeight="Normal"
                Foreground="{x:Bind ViewModel.AverageValueColor, Mode=OneWay}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.AverageValue, Mode=OneWay}" />

            <!--  unit, only visible in compact mode  -->
            <!--  (to disambiguate sensors that share the exact same name)  -->
            <TextBlock
                x:Name="UnitText"
                Grid.Column="6"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.Unit, Mode=OneWay}"
                Visibility="Collapsed" />
        </Grid>


        <!--  custom visual states for SensorRowControl  -->
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="CardStates">

                <!--  normal states for whole row  -->
                <VisualState x:Name="Normal">
                    <VisualState.Setters>
                        <Setter Target="CardBackground.Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                        <Setter Target="CardContent.Opacity" Value="1.0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Hover">
                    <VisualState.Setters>
                        <Setter Target="CardBackground.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                        <Setter Target="CardContent.Opacity" Value="1.0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                    <VisualState.Setters>
                        <Setter Target="CardBackground.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                        <Setter Target="CardContent.Opacity" Value="0.7" />
                    </VisualState.Setters>
                </VisualState>

                <!--  checked states for whole row  -->
                <VisualState x:Name="Checked">
                    <VisualState.Setters>
                        <Setter Target="CardBackground.Background" Value="{ThemeResource CustomCheckedBackgroundBrush}" />
                        <Setter Target="CardContent.Opacity" Value="1.0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="CheckedHover">
                    <VisualState.Setters>
                        <Setter Target="CardBackground.Background" Value="{ThemeResource CustomCheckedHoverBrush}" />
                        <Setter Target="CardContent.Opacity" Value="1.0" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="CheckedPressed">
                    <VisualState.Setters>
                        <Setter Target="CardBackground.Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                        <Setter Target="CardContent.Opacity" Value="0.7" />
                    </VisualState.Setters>
                </VisualState>

            </VisualStateGroup>


            <!--  display states  -->
            <!--  controls whether the card is fully live, frozen/disabled, or name-only (hidden window)  -->
            <VisualStateGroup x:Name="DisplayStates">
                <VisualState x:Name="FullDetails" />

                <!--  sensor is disabled but not fully hidden, values are frozen, card ignores clicks/hover  -->
                <VisualState x:Name="Disabled">
                    <VisualState.Setters>
                        <Setter Target="CardContent.Opacity" Value="0.5" />
                    </VisualState.Setters>
                </VisualState>

            </VisualStateGroup>


            <!--  threshold label states  -->
            <VisualStateGroup x:Name="ThresholdIndicatorStates">
                <VisualState x:Name="IndicatorNormal" />

                <!--  (only when no threshold is configured yet)  -->
                <VisualState x:Name="IndicatorHover">
                    <VisualState.Setters>
                        <Setter Target="ThresholdIndicatorBorder.Background" Value="{ThemeResource ThresholdIndicatorHoverBrush}" />
                    </VisualState.Setters>
                </VisualState>

                <!--  (only when no threshold is configured yet)  -->
                <VisualState x:Name="IndicatorPressedUnconfigured">
                    <VisualState.Setters>
                        <Setter Target="ThresholdIndicatorBorder.Background" Value="{ThemeResource ThresholdIndicatorPressedBrush}" />
                        <Setter Target="ThresholdIndicatorBorder.Opacity" Value="1.0" />
                    </VisualState.Setters>
                </VisualState>

                <!--  pressed while a threshold color is already set  -->
                <VisualState x:Name="IndicatorPressedConfigured">
                    <VisualState.Setters>
                        <Setter Target="ThresholdIndicatorBorder.Opacity" Value="0.6" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>