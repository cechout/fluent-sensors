<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentSensors.Features.Performance.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fhControls="using:FluentSensors.Controls"
    xmlns:fhGraph="using:FluentSensors.Controls.SensorGraph"
    xmlns:local="using:FluentSensors.Features.Performance"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  header: control buttons  -->
        <Border
            Grid.Row="0"
            Padding="16,0,10,1"
            Background="Transparent"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="PerformanceTitleText"
                    Grid.Column="0"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="Performance" />

                <CommandBar
                    x:Name="PerformanceCommandBar"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    DefaultLabelPosition="Right">

                    <!--  placeholders, not final  -->
                    <AppBarButton x:Name="PlaceholderButtonOne" Label="Placeholder 1" />
                    <AppBarButton x:Name="PlaceholderButtonTwo" Label="Placeholder 2" />

                </CommandBar>

            </Grid>
        </Border>


        <!--  content: hardware selection sidebar + detail area  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--
                sidebar: hardware selection, one unified list for every category (Cpu/Ram are always present,
                Gpu/Storage/Network are added reactively as PerformanceViewModel discovers them)
            -->
            <Border
                Grid.Column="0"
                Background="Transparent"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.NavItems, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Margin="8" Spacing="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:PerformanceNavItemViewModel">
                                <Button
                                    Padding="8"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Click="NavItem_Click"
                                    Style="{StaticResource SubtleButtonStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--
                                            mini graph placeholder; real per-instance mini graphs are a
                                            separate future step, selection highlighting likewise
                                        -->
                                        <Border
                                            Grid.Column="0"
                                            Width="48"
                                            Height="38"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                            CornerRadius="4" />

                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="{x:Bind DisplayName, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>


            <!--  detail area  -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  header: group label (left) + hardware display name (right) for the selected nav item  -->
                <Border
                    Grid.Row="0"
                    Padding="16,12,16,12"
                    Background="Transparent"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock
                            HorizontalAlignment="Left"
                            Style="{ThemeResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind ViewModel.SelectedItem.GroupLabel, Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.SelectedItem.DisplayName, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>

                <!--
                    CPU detail content; visible only while a CPU nav item is selected. Additional detail
                    blocks for Ram/Gpu/Storage/Network will follow the same pattern (own Grid.Row="1"
                    element, own ShowIfXSelected visibility) once built
                -->
                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Auto"
                    Visibility="{x:Bind ShowIfCpuSelected(ViewModel.SelectedItem), Mode=OneWay}">
                    <StackPanel Padding="16" Spacing="12">

                        <!--
                            both views below enforce a minimum graph/cell height (MinHeight / MinCellHeight);
                            once the available space can't fit that anymore, the ScrollViewer above scrolls
                            instead of squeezing everything down to unusable size
                        -->
                        <Grid>

                            <!--  overall CPU load: single graph  -->
                            <fhGraph:SensorPanelControl
                                MinHeight="150"
                                GraphDataPointsOverride="110"
                                IsAutoScaledOverride="False"
                                ManualYMaxOverride="100"
                                Mode="Performance"
                                ThresholdLabelAlwaysVisible="False"
                                ViewModel="{x:Bind ViewModel.Cpu.TotalLoad, Mode=OneWay}"
                                Visibility="{x:Bind ShowIfFalse(ViewModel.Cpu.IsShowingAllThreads), Mode=OneWay}" />

                            <!--
                                all cores/threads: dynamic square grid, one mini panel per core/thread. The
                                ItemsControl's own default internal ScrollViewer is disabled here so its
                                content's true (possibly grown-beyond-viewport) height bubbles up to the outer
                                ScrollViewer instead of scrolling twice
                            -->
                            <ItemsControl
                                ItemsSource="{x:Bind ViewModel.Cpu.Cores, Mode=OneWay}"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollMode="Disabled"
                                Visibility="{x:Bind ShowIfTrue(ViewModel.Cpu.IsShowingAllThreads), Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <fhControls:SquareGridPanel MinCellHeight="150" Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="fhGraph:SensorGraphViewModel">
                                        <fhGraph:SensorPanelControl
                                            GraphDataPointsOverride="50"
                                            IsAutoScaledOverride="False"
                                            ManualYMaxOverride="100"
                                            Mode="Performance"
                                            ThresholdLabelAlwaysVisible="False"
                                            ViewModel="{x:Bind}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <!--  CPU bottom bar (Overall / All Threads toggle); same visibility as the CPU content above  -->
                <Border
                    Grid.Row="2"
                    Padding="16,0,10,1"
                    Background="Transparent"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    Visibility="{x:Bind ShowIfCpuSelected(ViewModel.SelectedItem), Mode=OneWay}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <CommandBar
                            Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="Transparent"
                            DefaultLabelPosition="Right"
                            IsDynamicOverflowEnabled="False"
                            IsOpen="False">

                            <CommandBar.Resources>
                                <SolidColorBrush x:Key="CommandBarBackground" Color="Transparent" />
                                <SolidColorBrush x:Key="CommandBarBackgroundOpen" Color="Transparent" />
                                <SolidColorBrush x:Key="CommandBarBorderBrushOpen" Color="Transparent" />

                                <Thickness x:Key="AppBarButtonPadding">0,0,0,0</Thickness>
                            </CommandBar.Resources>

                            <AppBarButton
                                x:Name="ShowOverallButton"
                                Click="ShowOverall_Click"
                                Label="Overall">
                                <AppBarButton.Icon>
                                    <FontIcon Glyph="&#xE9D9;" />
                                </AppBarButton.Icon>
                            </AppBarButton>

                            <AppBarButton
                                x:Name="ShowAllThreadsButton"
                                Click="ShowAllThreads_Click"
                                Label="All Threads">
                                <AppBarButton.Icon>
                                    <FontIcon Glyph="&#xE80A;" />
                                </AppBarButton.Icon>
                            </AppBarButton>

                        </CommandBar>

                    </Grid>
                </Border>

            </Grid>

        </Grid>
    </Grid>
</Page>