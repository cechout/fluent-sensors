<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FluentSensors.Features.Performance.PerformancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fhControls="using:FluentSensors.Controls"
    xmlns:fhGraph="using:FluentSensors.Controls.SensorGraph"
    xmlns:fhLhm="using:FluentSensors.Features.Performance.Lhm"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  header: control buttons  -->
        <!--  (border has background: {ThemeResource SolidBackgroundFillColorTertiaryBrush})  -->
        <!--  (also: controlbar has automatic right padding, thats why here only padding 10 on the right)  -->
        <Border
            Grid.Row="0"
            Padding="16,0,10,1"
            Background="Transparent"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="PerformanceTitleText"
                    Grid.Column="0"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="Performance" />

                <CommandBar
                    x:Name="PerformanceCommandBar"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    DefaultLabelPosition="Right">

                    <!--  placeholders, not final  -->
                    <AppBarButton x:Name="PlaceholderButtonOne" Label="Placeholder 1" />
                    <AppBarButton x:Name="PlaceholderButtonTwo" Label="Placeholder 2" />

                </CommandBar>

            </Grid>
        </Border>


        <!--  content: hardware selection sidebar + detail area  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  sidebar: hardware selection  -->
            <Border
                Grid.Column="0"
                Background="Transparent"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                    <StackPanel Margin="8" Spacing="4">

                        <!--  CPU: always exactly one instance, not a collection  -->
                        <Button
                            Padding="8"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Style="{StaticResource SubtleButtonStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Width="48"
                                    Height="38"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="4" />

                                <TextBlock
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="CPU" />
                            </Grid>
                        </Button>

                        <!--  RAM: always exactly one instance, not a collection  -->
                        <Button
                            Padding="8"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Width="48"
                                    Height="38"
                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="4" />

                                <TextBlock
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="RAM" />
                            </Grid>
                        </Button>

                        <!--  GPU: dynamic, one entry per detected GPU  -->
                        <!--<TextBlock
                            Margin="8,8,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="GPU" />-->

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Gpu.Gpus, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="fhLhm:LhmGpuInstanceViewModel">
                                    <Button
                                        Padding="8"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Style="{StaticResource SubtleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border
                                                Grid.Column="0"
                                                Width="48"
                                                Height="38"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" />

                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{x:Bind HardwareName}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Storage: dynamic, one entry per detected drive  -->
                        <!--<TextBlock
                            Margin="8,8,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Storage" />-->

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Storage.Drives, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="fhLhm:LhmStorageInstanceViewModel">
                                    <Button
                                        Padding="8"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Style="{StaticResource SubtleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border
                                                Grid.Column="0"
                                                Width="48"
                                                Height="38"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" />

                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{x:Bind HardwareName}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Network: dynamic, one entry per active adapter  -->
                        <!--<TextBlock
                            Margin="8,8,0,0"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="Network" />-->

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Network.Adapters, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="fhLhm:LhmNetworkInstanceViewModel">
                                    <Button
                                        Padding="8"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Style="{StaticResource SubtleButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border
                                                Grid.Column="0"
                                                Width="48"
                                                Height="38"
                                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                CornerRadius="4" />

                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="{x:Bind HardwareName}"
                                                TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </Border>


            <!--  detail area  -->
            <Grid Grid.Column="1" Padding="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  toggle: Overall vs. All Threads, plain buttons for now, not final  -->
                <StackPanel
                    Grid.Row="0"
                    Margin="0,0,0,12"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        x:Name="ShowOverallButton"
                        Click="ShowOverall_Click"
                        Content="Overall" />
                    <Button
                        x:Name="ShowAllThreadsButton"
                        Click="ShowAllThreads_Click"
                        Content="All Threads" />
                </StackPanel>

                <!--  overall CPU load: single graph  -->
                <fhGraph:SensorPanelControl
                    Grid.Row="1"
                    GraphDataPointsOverride="110"
                    IsAutoScaledOverride="False"
                    ManualYMaxOverride="100"
                    Mode="Performance"
                    ThresholdLabelAlwaysVisible="False"
                    ViewModel="{x:Bind ViewModel.Cpu.TotalLoad, Mode=OneWay}"
                    Visibility="{x:Bind ShowIfFalse(ViewModel.Cpu.IsShowingAllThreads), Mode=OneWay}" />

                <!--  all cores/threads: dynamic square grid, one mini panel per core/thread  -->
                <ItemsControl
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Cpu.Cores, Mode=OneWay}"
                    Visibility="{x:Bind ShowIfTrue(ViewModel.Cpu.IsShowingAllThreads), Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <fhControls:SquareGridPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="fhGraph:SensorGraphViewModel">
                            <fhGraph:SensorPanelControl
                                Margin="2"
                                GraphDataPointsOverride="50"
                                IsAutoScaledOverride="False"
                                ManualYMaxOverride="100"
                                Mode="Performance"
                                ThresholdLabelAlwaysVisible="False"
                                ViewModel="{x:Bind}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>

        </Grid>
    </Grid>
</Page>